{
  "name": "karuna-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "web"
  ],
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "expo": "55.0.17",
    "react-native": "0.85.2",
    "react-native-reanimated": "4.3.0",
    "metro": "0.101.5",
    "metro-cache": "0.101.5",
    "metro-config": "0.101.5",
    "metro-core": "0.101.5",
    "metro-resolver": "0.101.5"
  },
  "scripts": {
    "backend:dev": "npm --workspace backend run start:dev",
    "backend:build": "npm --workspace backend run build",
    "backend:test": "npm --workspace backend test",
    "backend:prisma:generate": "npm --workspace backend run prisma:generate",
    "mobile:start": "npm --workspace mobile run start",
    "mobile:android": "npm --workspace mobile run android",
    "mobile:ios": "npm --workspace mobile run ios",
    "web:dev": "npm --workspace web run dev",
    "web:build": "npm --workspace web run build",
    "build": "npm run backend:build && npm run web:build",
    "test": "npm run backend:test",
    "postinstall": "npm run backend:prisma:generate"
  }
}
